# Template for the local .env file this project reads its Gmail
# credentials from. Copy this to a file named ".env" (no .example)
# and fill in your real values there -- .env is git-ignored and will
# never be committed. See the README's "Email alerts" section for how
# to generate the app password.

GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Optional: send alerts to a different address than GMAIL_ADDRESS.
# Leave unset to send alerts to yourself (GMAIL_ADDRESS).
# ALERT_EMAIL_TO=

# Optional: how many consecutive failed checks before alerting.
# ALERT_FAILURE_THRESHOLD=2
